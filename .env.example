# Phoenix runtime configuration
PHX_SERVER=true
PHX_HOST=localhost
PORT=4000

# Database configuration
DATABASE_URL=ecto://postgres:postgres@localhost/money_tree_dev
POOL_SIZE=10

# Secrets
SECRET_KEY_BASE=please_replace_with_secret
CLOAK_VAULT_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# Oban queue sizing
OBAN_DEFAULT_LIMIT=10
OBAN_MAILER_LIMIT=5
OBAN_REPORTING_LIMIT=5

# Optional telemetry export configuration
OTEL_EXPORTER_OTLP_ENDPOINT=

# Mail delivery
# Default sender used for notifications, invitations, and future magic links.
MAILER_FROM_NAME=MoneyTree
MAILER_FROM_EMAIL=no-reply@moneytree.app
# Optional invitation accept URL base; useful when the app is not served from the default host.
INVITATION_BASE_URL=
# Optional sign-in link URL base; useful when the public login host differs from local defaults.
MAGIC_LINK_BASE_URL=
# Optional WebAuthn overrides. Defaults follow the Phoenix endpoint host when blank.
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME=
WEBAUTHN_ORIGIN=
# Development can point these at any SMTP server. Production should use Amazon SES SMTP credentials.
MAILER_SMTP_HOST=
MAILER_SMTP_PORT=
MAILER_SMTP_USERNAME=
MAILER_SMTP_PASSWORD=
MAILER_SMTP_TLS=
MAILER_SMTP_SSL=
MAILER_SMTP_AUTH=
# Optional TLS certificate verification override for development. Do not disable verification in production.
MAILER_SMTP_VERIFY=

# Teller integration
# Required in production. Application ID from the Teller Console for Connect links.
# Find this on the Connect page in the Teller Console.
TELLER_CONNECT_APPLICATION_ID=
# Required in production. Webhook signing secret provided by Teller.
# Teller surfaces it when you create a webhook signing key; rotate it if leaked.
TELLER_WEBHOOK_SECRET=
# Optional overrides for non-default Teller endpoints (rare; useful for sandbox testing).
# Override only if Teller support directs you to a different host.
TELLER_API_HOST=
TELLER_CONNECT_HOST=
TELLER_WEBHOOK_HOST=
# Required in production for Teller API access. Provide either inline PEM values or file paths.
# When using PEM variables, keep the line breaks intact. File variables should point to
# readable paths on disk.
TELLER_CERT_PEM=
TELLER_KEY_PEM=
TELLER_CERT_FILE=
TELLER_KEY_FILE=
