{
  "name": "@moneytree/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate": "pnpm run generate:openapi && pnpm run generate:graphql",
    "generate:openapi": "openapi-typescript \"specs/openapi.yaml\" --output \"src/generated/rest.ts\"",
    "generate:graphql": "graphql-codegen --config codegen.ts",
    "verify": "pnpm run verify:openapi && pnpm run verify:graphql",
    "verify:openapi": "openapi-typescript \"specs/openapi.yaml\" --output \"src/generated/rest.ts\" --check",
    "verify:graphql": "graphql-codegen --config codegen.ts --check"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0",
    "graphql": "^16.13.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@graphql-codegen/typed-document-node": "^6.1.7",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.5.4"
  }
}
